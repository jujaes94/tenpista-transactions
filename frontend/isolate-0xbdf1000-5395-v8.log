script-source,79,/sessions/adoring-busy-carson/mnt/transactions-app/frontend/node_modules/import-local/index.js,'use strict';\nconst path = require('path');\nconst {fileURLToPath} = require('url');\nconst resolveCwd = require('resolve-cwd');\nconst pkgDir = require('pkg-dir');\n\nmodule.exports = filename => {\n\x09const normalizedFilename = filename.startsWith('file://') ? fileURLToPath(filename) : filename;\n\x09const globalDir = pkgDir.sync(path.dirname(normalizedFilename));\n\x09const relativePath = path.relative(globalDir\x2C normalizedFilename);\n\x09const pkg = require(path.join(globalDir\x2C 'package.json'));\n\x09const localFile = resolveCwd.silent(path.join(pkg.name\x2C relativePath));\n\x09const localNodeModules = path.join(process.cwd()\x2C 'node_modules');\n\n\x09const filenameInLocalNodeModules = !path.relative(localNodeModules\x2C normalizedFilename).startsWith('..') &&\n\x09\x09// On Windows\x2C if `localNodeModules` and `normalizedFilename` are on different partitions\x2C `path.relative()` returns the value of `normalizedFilename`\x2C resulting in `filenameInLocalNodeModules` incorrectly becoming `true`.\n\x09\x09path.parse(localNodeModules).root === path.parse(normalizedFilename).root;\n\n\x09// Use `path.relative()` to detect local package installation\x2C\n\x09// because __filename's case is inconsistent on Windows\n\x09// Can use `===` when targeting Node.js 8\n\x09// See https://github.com/nodejs/node/issues/6624\n\x09return !filenameInLocalNodeModules && localFile && path.relative(localFile\x2C normalizedFilename) !== '' && require(localFile);\n};\n
